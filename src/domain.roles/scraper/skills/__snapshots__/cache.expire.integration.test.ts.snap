"🦎 rock solid

📽️ cache.expire --help

usage:
  rhx cache.expire --for EMAIL --cache-dir PATH

options:
  --help                show this message
  --for EMAIL           account email to expire cache for (required)
  --cache-dir PATH      path to cache directory (required)

description:
  expires (deletes) all cache files for a given account.
  next query for this account will trigger a fresh scrape.

example:
  rhx cache.expire --for user@example.com --cache-dir .cache/myapp
"
