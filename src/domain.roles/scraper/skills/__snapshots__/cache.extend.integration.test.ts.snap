"🦎 rock solid

📽️ cache.extend --help

usage:
  rhx cache.extend --for EMAIL --by DURATION --cache-dir PATH

options:
  --help                show this message
  --for EMAIL           account email to extend cache for (required)
  --by DURATION         ISO 8601 duration, e.g., PT24H, PT1H30M (required)
  --cache-dir PATH      path to cache directory (required)

description:
  extends cache ttl for a given account. sets expiresAtMse
  to now + duration. idempotent: safe to call multiple times.

example:
  rhx cache.extend --for user@example.com --by PT24H --cache-dir .cache/myapp
"
