   │  ├─ .cache/browser.test-snapshot/snapshot.ISOTIME.tabN/snapshot.console.json
   │  ├─ .cache/browser.test-snapshot/snapshot.ISOTIME.tabN/snapshot.html
   │  ├─ .cache/browser.test-snapshot/snapshot.ISOTIME.tabN/snapshot.meta.json
