"
`;

exports[`browser.snapshot given: [case6] --help when: [t0] browser.snapshot is called with --help then: output matches snapshot 1`] = `
"🦎 lets get some sun...

📽️ browser.snapshot --help
   ├─ purpose: capture diagnostic snapshot of browser tab
   ├─ usage: browser.snapshot [subcommand] --focused | --tab N --url 'pattern'
   └─ options
      ├─ --help: show this message
      ├─ --focused: snapshot the focused tab
      ├─ --tab N: tab index (0-based, negative from end)
      ├─ --url 'pattern': verify tab URL contains pattern (required with --tab)
      ├─ --session NAME: browser session name (default: default)
      ├─ --output PATH: output directory prefix
      └─ subcommands: screen, html, meta, console, network, storage
"
`;
