exports[`browser.journey given: [case1] happy path workflow when: [t3] browser.snapshot captures state then: output matches snapshot 1`] = `
"🦎 toasty

📽️ browser.snapshot
   ├─ session: test-journey
   ├─ tab: 0
   │
   ├─ ✓ snapshot.meta.json
   ├─ ✓ snapshot.png
   ├─ ✓ snapshot.html
   ├─ ✓ snapshot.console.json
   ├─ ✓ snapshot.storage.json
   ├─ ✓ snapshot.network.json
   │
   ├─ output
   │  ├─ .cache/browser.test-journey/snapshot.ISOTIME.tabN/snapshot.console.json
   │  ├─ .cache/browser.test-journey/snapshot.ISOTIME.tabN/snapshot.html
   │  ├─ .cache/browser.test-journey/snapshot.ISOTIME.tabN/snapshot.meta.json
   │  ├─ .cache/browser.test-journey/snapshot.ISOTIME.tabN/snapshot.network.json
   │  ├─ .cache/browser.test-journey/snapshot.ISOTIME.tabN/snapshot.png
   │  └─ .cache/browser.test-journey/snapshot.ISOTIME.tabN/snapshot.storage.json
   │
   └─ done
"
`;

