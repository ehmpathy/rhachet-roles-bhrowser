// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`browser.journey given: [case1] happy path workflow when: [t0] browser.start launches browser then: output matches snapshot 1`] = `
"🦎 lets get some sun

📽️ browser.start
   ├─ session: test-journey
   ├─ mode: HEADLESS
   ├─ port: PORT
   ├─ wsEndpoint: ws://localhost:PORT/devtools/browser/UUID
   ├─ state: .cache/browser.test-journey/ws-endpoint
   │
   ├─ tests will auto-discover and reuse this window
   │
   └─ to stop: rhx browser.stop --session test-journey
"
`;

